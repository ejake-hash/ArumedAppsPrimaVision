# Copy ke .env lalu sesuaikan
VITE_API_URL=http://localhost:8000/api/v1

# Antrean realtime (Laravel Reverb / WebSocket). KOSONGKAN = fallback polling 8s.
# Untuk realtime: isi VITE_REVERB_APP_KEY (samakan dgn REVERB_APP_KEY backend) +
# host/port server WS yang dijangkau browser. Wajib `npm run build` ulang setelah diisi.
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
