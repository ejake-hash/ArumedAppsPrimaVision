# Konfigurasi integrasi OCT ↔ Arumed (dibaca feeder & bridge).
# Taruh di /etc/arumed-oct.env (chmod 600, milik root) — berisi token rahasia.

# Base URL Arumed (server yang sama → localhost).
ARUMED_BASE=http://127.0.0.1:8000

# Token mesin = PENUNJANG_BRIDGE_TOKEN di .env Arumed (WAJIB sama).
# JANGAN commit token asli. Isi nilai sebenarnya hanya di /etc/arumed-oct.env server.
PENUNJANG_BRIDGE_TOKEN=GANTI-DENGAN-TOKEN-SAMA-DENGAN-.ENV-SERVER

# Folder worklist Orthanc (harus sama dgn orthanc-arumed.json → Worklists.Database).
WORKLIST_DIR=/var/lib/orthanc/worklists

# AE Title yang dipakai OCT (isi di IMAGEnet sbg Client AE Title). Dicantumkan di .wl.
OCT_AET=MAESTRO

# Filter modality worklist (kosong = semua). OCT Maestro = OPT.
WL_MODALITY=OPT

# REST Orthanc (localhost).
ORTHANC_URL=http://127.0.0.1:8042

# Sumber yang dilaporkan ke Arumed saat ingest hasil OCT.
INGEST_SOURCE=OCT
