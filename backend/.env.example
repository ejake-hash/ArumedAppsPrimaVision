APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Antrean realtime. Default `log` = TIDAK broadcast (frontend fallback polling 8s).
# Untuk realtime WebSocket di PRODUKSI: ubah ke `reverb`, isi kredensial REVERB_*
# di bawah, lalu jalankan proses `php artisan reverb:start` (supervisor/systemd).
# Channel antrean semuanya PUBLIC → tidak perlu broadcasting auth route.
BROADCAST_CONNECTION=log

# Token mesin untuk bridge/watcher integrasi alat penunjang (DICOM worklist + ingest PDF).
# Dipakai endpoint /api/v1/integrasi/penunjang/* (middleware service-token). Isi string acak
# panjang; biarkan KOSONG = endpoint mesin tertutup total (aman default).
PENUNJANG_BRIDGE_TOKEN=

# Laravel Reverb (WebSocket server) — isi saat mengaktifkan realtime.
# REVERB_APP_ID/KEY/SECRET: bebas, samakan dgn yang dipakai frontend (KEY).
# REVERB_HOST/PORT: alamat server WS yang dijangkau BROWSER (publik), mis.
#   ws.kliniku.id : 443 (di balik reverse-proxy WSS). Lokal: localhost:8080.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
# Host/port tempat proses reverb:start MENDENGAR (biasanya 0.0.0.0:8080).
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# JWT — generate secret via: php artisan jwt:secret
JWT_SECRET=
# Fallback TTL token (menit). Login normal di-override AuthService agar
# kedaluwarsa jam 24.00 WIB; nilai ini hanya untuk jalur lain. 720 = 12 jam.
JWT_TTL=720
